JARVIS_PORT=8787
SUPABASE_DB_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres
SUPABASE_PROJECT_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-server-only-secret-key
JARVIS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JARVIS_ALLOW_INSECURE_DEV_AUTH=false
JARVIS_RUNTIME_MODE=cli
PG_FAMILY=4
PG_CONNECTION_TIMEOUT_MS=15000
OPENCLAUDE_BIN=openclaude.cmd
OPENCLAUDE_PROVIDER=openai
OPENCLAUDE_MODEL=codexplan
OPENCLAUDE_AGENT=torq-orchestrator
OPENCLAUDE_TIMEOUT_MS=180000
